<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:userControls="clr-namespace:Valt.UI.UserControls"
        xmlns:lang="clr-namespace:Valt.UI.Lang"
        xmlns:updateLoanState="clr-namespace:Valt.UI.Views.Main.Modals.UpdateLoanState"
        mc:Ignorable="d"
        x:Class="Valt.UI.Views.Main.Modals.UpdateLoanState.UpdateLoanStateView"
        Title="{Binding WindowTitle}"
        x:DataType="updateLoanState:UpdateLoanStateViewModel"
        d:DesignWidth="550"
        d:DesignHeight="650"
        MinWidth="550"
        MinHeight="650"
        MaxWidth="550"
        MaxHeight="650"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="0">
    <Design.DataContext>
        <updateLoanState:UpdateLoanStateViewModel />
    </Design.DataContext>
    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}" />
    </Window.KeyBindings>
    <Border>
        <StackPanel Orientation="Vertical">
            <userControls:CustomTitleBar Title="{Binding WindowTitle}"
                                         TitleBarPressed="CustomTitleBarButtonPressed"
                                         CloseClick="CustomTitleBarCloseClicked" />
            <Border Classes="form-fields-area" Height="560" Padding="16">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <!-- Current Loan Context -->
                        <Border Classes="form-section">
                            <StackPanel>
                                <TextBlock Classes="form-section-header"
                                           Text="{x:Static lang:language.UpdateLoanState_ContextHeader}" />
                                <Grid ColumnDefinitions="*, 32, *"
                                      RowDefinitions="Auto, Auto, Auto, Auto"
                                      RowSpacing="16"
                                      ColumnSpacing="32">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_Platform}" />
                                        <TextBlock Text="{Binding PlatformName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="2" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_LoanAmount}" />
                                        <TextBlock Text="{Binding LoanAmountFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_InitialLTV}" />
                                        <TextBlock Text="{Binding InitialLtvFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="2" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_MarginCallLTV}" />
                                        <TextBlock Text="{Binding MarginCallLtvFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="2" Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_LiquidationLTV}" />
                                        <TextBlock Text="{Binding LiquidationLtvFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="2" Grid.Column="2" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_LoanStartDate}" />
                                        <TextBlock Text="{Binding LoanStartDateFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="3" Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_RepaymentDate}" />
                                        <TextBlock Text="{Binding RepaymentDateFormatted}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text100Brush}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- New State -->
                        <Border Classes="form-section">
                            <StackPanel>
                                <TextBlock Classes="form-section-header"
                                           Text="{x:Static lang:language.UpdateLoanState_NewStateHeader}" />
                                
                                <StackPanel Classes="form-field">
                                    <TextBlock Text="{x:Static lang:language.UpdateLoanState_EffectiveDate}" />
                                    <CalendarDatePicker HorizontalAlignment="Left"
                                                        SelectedDateFormat="Short"
                                                        IsTodayHighlighted="True"
                                                        Height="36"
                                                        SelectedDate="{Binding EffectiveDate}" />
                                </StackPanel>
                                
                                <Grid ColumnDefinitions="*, 32, *">
                                    <StackPanel Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.UpdateLoanState_CurrentTotalDebt}" />
                                        <userControls:FiatInput FiatValue="{Binding CurrentTotalDebt, Mode=TwoWay}"
                                                                CurrencySymbol="{Binding CurrencySymbol}"
                                                                SymbolOnRight="{Binding SymbolOnRight}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_CollateralSats}" />
                                        <TextBox Text="{Binding CollateralSats}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*, 32, *">
                                    <StackPanel Grid.Column="0" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_APR}" />
                                        <TextBox Text="{Binding AprPercentage}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Classes="form-field">
                                        <TextBlock Text="{x:Static lang:language.ManageAsset_Fees}" />
                                        <userControls:FiatInput FiatValue="{Binding Fees, Mode=TwoWay}"
                                                                CurrencySymbol="{Binding CurrencySymbol}"
                                                                SymbolOnRight="{Binding SymbolOnRight}" />
                                    </StackPanel>
                                </Grid>
                                
                                <StackPanel Classes="form-field">
                                    <TextBlock Text="{x:Static lang:language.UpdateLoanState_Note}" />
                                    <TextBox Text="{Binding Note}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Margin="0, 10, 0, 10">
                <Button Padding="8,6"
                        Content="{x:Static lang:language.UpdateLoanState_SaveSnapshot}"
                        HorizontalContentAlignment="Center"
                        Command="{Binding OkCommand}"
                        IsDefault="True" />
                <Button Padding="8,6"
                        Content="{x:Static lang:language.UpdateLoanState_DiscardChanges}"
                        HorizontalContentAlignment="Center"
                        Command="{Binding CancelCommand}"
                        IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
