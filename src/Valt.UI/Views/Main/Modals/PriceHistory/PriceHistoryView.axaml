<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:userControls="clr-namespace:Valt.UI.UserControls"
        xmlns:lang="clr-namespace:Valt.UI.Lang"
        xmlns:vm="clr-namespace:Valt.UI.Views.Main.Modals.PriceHistory"
        xmlns:avalonia="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d"
        d:DesignWidth="900" d:DesignHeight="700"
        MinWidth="900"
        MinHeight="700"
        MaxWidth="900"
        MaxHeight="700"
        x:Class="Valt.UI.Views.Main.Modals.PriceHistory.PriceHistoryView"
        x:DataType="vm:PriceHistoryViewModel"
        Title="{x:Static lang:language.PriceHistory_Title}"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="None"
        ExtendClientAreaTitleBarHeightHint="0">
    <Design.DataContext>
        <vm:PriceHistoryViewModel />
    </Design.DataContext>
    <Border Name="MainBorder" Focusable="True">
        <StackPanel Orientation="Vertical">
            <userControls:CustomTitleBar Title="{x:Static lang:language.PriceHistory_Title}"
                                         TitleBarPressed="CustomTitleBarButtonPressed"
                                         CloseClick="CustomTitleBarCloseClicked" />
            <Border Classes="form-fields-area" Padding="0">
                <Grid ColumnDefinitions="180, *" Height="655">
                    <!-- Left panel: Currency selector -->
                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource Background700Brush}"
                            BorderThickness="0,0,1,0"
                            Padding="10">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <ListBox ItemsSource="{Binding AvailableCurrencies}"
                                     SelectedItem="{Binding SelectedCurrency}"
                                     MaxHeight="620">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="4,2" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Right panel: Chart + Pagination + DataGrid -->
                    <Grid Grid.Column="1" RowDefinitions="250, Auto, *">
                        <!-- Chart -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource Background900Brush}"
                                BorderBrush="{DynamicResource Background700Brush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10"
                                Margin="10,10,10,0"
                                IsVisible="{Binding HasData}">
                            <avalonia:CartesianChart
                                x:Name="PriceChart"
                                Background="{DynamicResource Background900Brush}"
                                Series="{Binding ChartData.Series}"
                                XAxes="{Binding ChartData.XAxes}"
                                YAxes="{Binding ChartData.YAxes}"
                                TooltipTextSize="12"
                                ZoomMode="None"
                                Height="220"
                                Margin="10,5,10,5" />
                        </Border>

                        <!-- No data message -->
                        <TextBlock Grid.Row="0"
                                   Text="{x:Static lang:language.PriceHistory_NoData}"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   Foreground="{DynamicResource Text400Brush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !HasData}" />

                        <!-- Pagination bar -->
                        <Border Grid.Row="1" Margin="10,8,10,0" Padding="4">
                            <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                                <Button Grid.Column="0"
                                        Content="{x:Static lang:language.PriceHistory_Previous}"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding CanGoBack}"
                                        Classes="transparent" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                                    <TextBlock Text="{Binding PageInfo}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text300Brush}" />
                                    <TextBlock Text="{Binding TotalRecordsText}"
                                               VerticalAlignment="Center"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource Text500Brush}" />
                                </StackPanel>
                                <Button Grid.Column="4"
                                        Content="{x:Static lang:language.PriceHistory_Next}"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding CanGoForward}"
                                        Classes="transparent" />
                            </Grid>
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="2"
                                  Margin="10,5,10,10"
                                  GridLinesVisibility="All"
                                  ItemsSource="{Binding PageItems}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static lang:language.PriceHistory_Column_Date}"
                                                    Binding="{Binding Date}"
                                                    Width="200" />
                                <DataGridTextColumn Header="{Binding PriceColumnHeader}"
                                                    Binding="{Binding Price}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</Window>
