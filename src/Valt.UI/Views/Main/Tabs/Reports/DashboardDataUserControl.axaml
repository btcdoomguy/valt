<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Valt.UI.Views.Main.Tabs.Reports"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="250"
             x:Class="Valt.UI.Views.Main.Tabs.Reports.DashboardDataUserControl"
             x:DataType="vm:DashboardData">
    <UserControl.Styles>
        <!-- Stale state styles: gray out text when data is outdated -->
        <Style Selector="vm|DashboardDataUserControl.stale /template/ TextBlock#IconText">
            <Setter Property="Foreground" Value="{DynamicResource Text500Brush}" />
        </Style>
        <Style Selector="vm|DashboardDataUserControl.stale /template/ Label#TitleLabel">
            <Setter Property="Foreground" Value="{DynamicResource Text500Brush}" />
        </Style>
        <Style Selector="vm|DashboardDataUserControl.stale TextBlock#LeftTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text500Brush}" />
        </Style>
        <Style Selector="vm|DashboardDataUserControl.stale TextBlock#RightTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text400Brush}" />
        </Style>
    </UserControl.Styles>
    <Design.DataContext>
        <x:Static Member="vm:DashboardData.DesignTimeSample" />
    </Design.DataContext>
    <Border BorderThickness="1"
            Background="{DynamicResource Background800Brush}"
            BorderBrush="{DynamicResource Background700Brush}"
            CornerRadius="4"
            Width="320">

        <StackPanel Orientation="Vertical">
            <Border Background="{DynamicResource Background600Brush}"
                    Padding="12, 8"
                    CornerRadius="4, 4, 0, 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="IconText"
                                   FontFamily="{DynamicResource MaterialDesign}"
                                   Text="{Binding Icon}"
                                   FontSize="13"
                                   Foreground="{DynamicResource Accent200Brush}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <Label x:Name="TitleLabel"
                               HorizontalContentAlignment="Left"
                               Content="{Binding Title}"
                               Foreground="{DynamicResource Accent200Brush}"
                               FontSize="{DynamicResource FontSizeNormal}"
                               FontWeight="SemiBold"
                               Padding="0" />
                    </StackPanel>

                    <!-- Settings gear icon - only visible when HasConfiguration is true -->
                    <Button Grid.Column="1"
                            Classes="transparent"
                            IsVisible="{Binding HasConfiguration}"
                            Margin="-4"
                            Command="{Binding ConfigureCommand}"
                            ToolTip.Tip="Configure"
                            Padding="0"
                            MinWidth="16"
                            MinHeight="16">
                        <TextBlock FontFamily="{DynamicResource MaterialDesign}"
                                   Text="&#xE8B8;"
                                   FontSize="16"
                                   Foreground="{DynamicResource Text300Brush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter:nth-child(odd)">
                        <Setter Property="Background" Value="{DynamicResource Background800Brush}" />
                    </Style>
                    <Style Selector="ItemsControl > ContentPresenter:nth-child(even)">
                        <Setter Property="Background" Value="{DynamicResource Background900Brush}" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:RowItem">
                        <Panel>
                            <!-- Separator row -->
                            <Border Height="2"
                                    Background="{DynamicResource Background600Brush}"
                                    IsVisible="{Binding IsSeparator}" />

                            <!-- Normal data row -->
                            <Border Padding="12, 6"
                                    BorderBrush="{DynamicResource Background700Brush}"
                                    BorderThickness="0,0,0,1"
                                    ToolTip.Tip="{Binding Tooltip}"
                                    ToolTip.ShowDelay="300"
                                    Cursor="{Binding HasUrl, Converter={x:Static vm:DashboardDataConverters.CursorConverter}}"
                                    PointerPressed="OnRowPointerPressed"
                                    IsVisible="{Binding !IsSeparator}">

                                    <DockPanel LastChildFill="True" MinWidth="280">
                                        <TextBlock x:Name="LeftTextBlock"
                                                   Text="{Binding LeftText}"
                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource Text300Brush}"
                                                   DockPanel.Dock="Left"
                                                   Padding="0, 6, 15, 0"
                                                   VerticalAlignment="Center"
                                                   TextDecorations="{Binding HasUrl, Converter={x:Static vm:DashboardDataConverters.UnderlineConverter}}"/>

                                        <TextBlock x:Name="RightTextBlock"
                                                   Text="{Binding RightText}"
                                                   FontSize="{DynamicResource FontSizeSmall}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource Text100Brush}"
                                                   DockPanel.Dock="Right"
                                                   Padding="0, 4, 10, 0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap"/>
                                    </DockPanel>
                            </Border>
                        </Panel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
